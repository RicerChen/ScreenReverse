# 环境变量配置说明
# 复制此文件为 .env.local 并填入实际值

# ============================================
# 必填项
# ============================================

# 智谱 AI API Key
# 前往 https://open.bigmodel.cn/ 申请
ZHIPU_API_KEY=your_zhipu_api_key_here

# ============================================
# 可选项（有默认值）
# ============================================

# 智谱模型名称
# 默认: glm-4.7-flash
# 可选: glm-4-flash, glm-4, glm-4-plus, glm-4.7-flash, glm-4.7, glm-4.7-plus, glm-4.7-allTools 等
ZHIPU_MODEL=glm-4.7-flash

# 应用端口
# 默认: 3000
PORT=3000

# Node 环境
# 默认: development
# 生产环境: production
NODE_ENV=development

# Playwright 配置
# 是否无头模式运行浏览器
# 默认: true（生产环境建议 true）
PLAYWRIGHT_HEADLESS=true

# 页面加载超时时间（毫秒）
# 默认: 30000（30秒）
PLAYWRIGHT_TIMEOUT=30000

# 任务配置
# 单个任务超时时间（毫秒）
# 默认: 120000（2分钟）
TASK_TIMEOUT=120000

# 任务清理时间（毫秒）
# 默认: 86400000（24小时）
# 超过此时间的任务将被自动清理
TASK_CLEANUP_TTL=86400000

# 最大并发任务数
# 默认: 3
# 根据服务器性能调整
MAX_CONCURRENT_TASKS=3

# OCR 语言包
# 默认: chi_sim+eng（简体中文+英文）
# 可选: chi_sim（简体中文）, chi_tra（繁体中文）, eng（英文）等
# 多语言用 + 连接，如: chi_sim+eng+chi_tra
TESSERACT_LANGUAGE=chi_sim+eng
